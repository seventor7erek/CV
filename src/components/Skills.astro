---
import { skills } from "../data/skills";
---

<section id="skills" class="px-6 py-32">
  <div class="mx-auto max-w-6xl">
    <h2 data-reveal class="gsap-reveal mb-12 text-[2rem] font-semibold text-text-primary">Tech Stack</h2>
    <div class="flex flex-col gap-12">
      {skills.map((group) => (
        <div>
          <span data-reveal class="gsap-reveal mb-4 block text-xs uppercase tracking-widest text-text-muted">
            {group.category}
          </span>
          <div class="flex flex-wrap gap-2">
            {group.items.map((item) => (
              <span data-skill-chip class="gsap-reveal skill-chip inline-block rounded-lg px-4 py-2 text-sm text-text-primary">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .skill-chip {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(40px) saturate(180%);
    -webkit-backdrop-filter: blur(40px) saturate(180%);
    border: 0.5px solid rgba(255, 255, 255, 0.08);
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }
  .skill-chip:hover {
    background-color: rgba(239, 68, 68, 0.08);
    border-color: rgba(239, 68, 68, 0.15);
  }
</style>
