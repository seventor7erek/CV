---
---

<section id="skills" class="px-6 py-32">
  <div class="mx-auto max-w-6xl">
    <h2 data-reveal class="gsap-reveal mb-12 text-center text-[2rem] font-semibold text-text-primary">Tech Stack</h2>

    <!-- Globe -->
    <div class="flex items-center justify-center">
      <div class="relative">
        <div class="pointer-events-none absolute inset-0 flex items-center justify-center" aria-hidden="true">
          <div class="h-[28rem] w-[28rem] rounded-full bg-accent-glow blur-3xl"></div>
        </div>
        <canvas
          id="globe-canvas"
          class="relative z-10 h-[500px] w-[500px] cursor-grab active:cursor-grabbing sm:h-[600px] sm:w-[600px] md:h-[720px] md:w-[720px]"
        ></canvas>
      </div>
    </div>
  </div>
</section>

<script>
  import { initGlobe } from "../scripts/globe";

  const canvas = document.getElementById("globe-canvas") as HTMLCanvasElement | null;
  if (canvas) {
    initGlobe(canvas);
  }
</script>
