---
import { skills } from "../data/skills";
---

<section id="skills" class="px-6 py-32">
  <div class="mx-auto max-w-6xl">
    <h2 data-reveal class="gsap-reveal mb-12 text-center text-[2rem] font-semibold text-text-primary">Tech Stack</h2>
    <div class="flex flex-col items-center gap-12">
      {skills.map((group) => (
        <div class="text-center">
          <span data-reveal class="gsap-reveal mb-4 block text-xs uppercase tracking-widest text-text-muted">
            {group.category}
          </span>
          <div class="flex flex-wrap justify-center gap-2">
            {group.items.map((item) => (
              <span data-skill-chip class="gsap-reveal skill-chip inline-block rounded-lg px-4 py-2 text-sm text-text-primary">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .skill-chip {
    background: rgba(30, 30, 38, 0.55);
    backdrop-filter: blur(50px) saturate(190%) brightness(1.05);
    -webkit-backdrop-filter: blur(50px) saturate(190%) brightness(1.05);
    border: 0.5px solid rgba(255, 255, 255, 0.1);
    box-shadow: inset 0 0.5px 0 0 rgba(255, 255, 255, 0.07);
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }
  .skill-chip:hover {
    background-color: rgba(239, 68, 68, 0.15);
    border-color: rgba(239, 68, 68, 0.25);
  }
</style>
