---
interface Props {
  projectId?: string;
}

const { projectId = "hRFfUymDGOHwtFe7evR2" } = Astro.props;
---

<section id="energy-beam" class="energy-beam-section">
  <!-- Top fade: blends into the section above -->
  <div class="energy-beam-fade energy-beam-fade-top"></div>

  <!-- Unicorn Studio canvas container -->
  <div
    data-us-project={projectId}
    data-us-scale="1"
    data-us-dpi="1.5"
    class="energy-beam-canvas"
  ></div>

  <!-- Bottom fade: blends into footer below -->
  <div class="energy-beam-fade energy-beam-fade-bottom"></div>
</section>

<style is:global>
  .energy-beam-section {
    position: relative;
    width: 100%;
    height: 50vh;
    overflow: hidden;
    background: var(--bg-base);
  }

  .energy-beam-canvas {
    width: 100%;
    height: 100%;
  }

  /* Gradient fades so the beam bleeds into surrounding sections */
  .energy-beam-fade {
    position: absolute;
    left: 0;
    right: 0;
    height: 80px;
    z-index: 2;
    pointer-events: none;
  }

  .energy-beam-fade-top {
    top: 0;
    background: linear-gradient(to bottom, var(--bg-base), transparent);
  }

  .energy-beam-fade-bottom {
    bottom: 0;
    background: linear-gradient(to top, var(--bg-base), transparent);
  }

  /* Reduced motion: hide entirely */
  @media (prefers-reduced-motion: reduce) {
    .energy-beam-section {
      display: none;
    }
  }
</style>

<script>
  const section = document.getElementById("energy-beam");
  if (!section) throw new Error("energy-beam section not found");

  const beamCanvas = section.querySelector("[data-us-project]") as HTMLElement | null;
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!reducedMotion && beamCanvas) {
    let loaded = false;

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting && !loaded) {
          loaded = true;
          observer.disconnect();

          const script = document.createElement("script");
          script.src =
            "https://cdn.jsdelivr.net/gh/hiunicornstudio/unicornstudio.js@v1.5.2/dist/unicornStudio.umd.js";
          script.async = true;

          script.onload = () => {
            if (window.UnicornStudio) {
              window.UnicornStudio.addScene({
                elementId: beamCanvas.id || undefined,
                element: beamCanvas,
                projectId: beamCanvas.dataset.usProject!,
                scale: parseFloat(beamCanvas.dataset.usScale || "1"),
                dpi: parseFloat(beamCanvas.dataset.usDpi || "1.5"),
                fps: 60,
                interactivity: {
                  mouse: { disableMobile: false },
                },
              }).catch(() => {
                // Fallback: try generic init
                window.UnicornStudio!.init();
              });
            }
          };

          document.head.appendChild(script);
        }
      },
      { rootMargin: "200px" }
    );

    observer.observe(section);
  }

  // Type declaration for the SDK
  declare global {
    interface Window {
      UnicornStudio?: {
        init: () => void;
        addScene: (opts: Record<string, unknown>) => Promise<unknown>;
      };
    }
  }
</script>
