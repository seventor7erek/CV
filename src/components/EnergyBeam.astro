<section id="energy-beam" class="energy-beam-section">
  <!-- Top fade: blends into the section above -->
  <div class="energy-beam-fade energy-beam-fade-top"></div>

  <!-- Black hole canvas -->
  <canvas id="black-hole-canvas" class="energy-beam-canvas"></canvas>

  <!-- Closing tag easter egg -->
  <span class="energy-beam-tag font-mono">&lt;/&gt;</span>

  <!-- Bottom fade: blends into footer below -->
  <div class="energy-beam-fade energy-beam-fade-bottom"></div>
</section>

<style is:global>
  .energy-beam-section {
    position: relative;
    width: 100%;
    height: 50vh;
    overflow: hidden;
    background: var(--bg-base);
  }

  .energy-beam-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* Closing tag overlay */
  .energy-beam-tag {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 1;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    color: var(--accent);
    opacity: 0.06;
    pointer-events: none;
    user-select: none;
    letter-spacing: 0.15em;
  }

  /* Gradient fades so the vortex bleeds into surrounding sections */
  .energy-beam-fade {
    position: absolute;
    left: 0;
    right: 0;
    height: 80px;
    z-index: 2;
    pointer-events: none;
  }

  .energy-beam-fade-top {
    top: 0;
    background: linear-gradient(to bottom, var(--bg-base), transparent);
  }

  .energy-beam-fade-bottom {
    bottom: 0;
    background: linear-gradient(to top, var(--bg-base), transparent);
  }

  /* Reduced motion: static glow only */
  @media (prefers-reduced-motion: reduce) {
    .energy-beam-canvas {
      display: none;
    }
  }
</style>

<script>
  import { init } from "../scripts/black-hole";

  const canvas = document.getElementById("black-hole-canvas") as HTMLCanvasElement | null;
  if (canvas) {
    init(canvas);
  }
</script>
